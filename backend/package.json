    "ws": "^8.16.0",
    "node-pty": "^1.0.0",
    "dockerode": "^4.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "uuid": "^9.0.1",
    "express-rate-limit": "^7.1.5",
    "fs-extra": "^11.2.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "better-sqlite3": "^9.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.11.16",
    "@types/uuid": "^9.0.8",
    "@types/cors": "^2.8.17",
    "@types/fs-extra": "^11.0.4",
    "@types/dockerode": "^3.3.23",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/better-sqlite3": "^7.6.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
